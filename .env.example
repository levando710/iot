# MQTT broker (ví dụ HiveMQ Cloud)
MQTT_HOST=your-broker-host
MQTT_PORT=8883
MQTT_USER=your-username
MQTT_PASSWORD=your-password
MQTT_CLIENT_ID=ktx-server-local
MQTT_USE_TLS=1
MQTT_TLS_INSECURE=0
# MQTT_TLS_CA_CERT=path_to_ca_cert.pem

# Runtime
CAMERA_INDEX=0
CAMERA_URL=
# 5-camera setup (ưu tiên URL, nếu không có thì dùng INDEX)
CAMERA_KTX_IN_URL=
CAMERA_KTX_IN_INDEX=
CAMERA_KTX_OUT_URL=
CAMERA_KTX_OUT_INDEX=
CAMERA_PARK_IN_PLATE_URL=
CAMERA_PARK_IN_PLATE_INDEX=
CAMERA_PARK_OUT_PLATE_URL=
CAMERA_PARK_OUT_PLATE_INDEX=
CAMERA_PARK_OUT_FACE_URL=
CAMERA_PARK_OUT_FACE_INDEX=
QUEUE_MAXSIZE=20
VOICE_GUIDE_ENABLED=1
VOICE_GUIDE_RATE=160
VOICE_GUIDE_VOLUME=1.0
FACE_RETRY_COUNT=3
FACE_RETRY_INTERVAL_MS=2500

# YOLO model path (plate detection model)
YOLO_MODEL_PATH=yolov8n.pt
